        "import math\n",
        "\n",
        "print(\"Quadratic Solver!\")\n",
        "print(\"Enter x^2 coefficient:\")\n",
        "a = int(input())\n",
        "print(\"Enter x coefficient:\")\n",
        "b = int(input())\n",
        "print(\"Enter constant:\")\n",
        "c = int(input())\n",
        "print(f\"Your quadratic equation is ({a})x^2 + ({b})x + ({c})\")\n",
        "if (((b**2)-(4*a*c))<0):\n",
        "  print(\"Your quadratic equation has no real roots!\")\n",
        "elif(((b**2)-(4*a*c))==0):\n",
        "  x=-b/2*a\n",
        "  print(f\"X is equal to ({x})\")\n",
        "else:\n",
        "  x1 = (-b + math.sqrt((b**2)-(4*a*c)))/2*a\n",
        "  x2 = (-b - math.sqrt((b**2)-(4*a*c)))/2*a\n",
        "  print(f\"X is equal to ({x1}) or ({x2})\")"
      ],
